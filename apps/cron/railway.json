{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install",
    "watchPatterns": [
      "/apps/cron/**",
      "/packages/db/**",
      "/packages/shared/src/retention.ts"
    ]
  },
  "deploy": {
    "runtime": "V2",
    "cronSchedule": "0 3,15 * * *",
    "startCommand": "bun apps/cron/src/cleanup.ts",
    "restartPolicyType": "NEVER"
  }
}
