# Cloudflare Turnstile (test keys - always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# App name
NEXT_PUBLIC_APP_NAME=MyApp

# API URL (leave empty in dev - uses Next.js proxy)
# Set in production to your API domain
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# WebSocket URL (points directly to WS server in dev, omit in production where Caddy proxies /ws)
NEXT_PUBLIC_WS_URL=ws://localhost:3002
