  "dependencies": {
    "@app/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
