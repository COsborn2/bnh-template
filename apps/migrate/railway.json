{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install",
    "watchPatterns": [
      "/apps/migrate/**",
      "/packages/db/**"
    ]
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "bun apps/migrate/src/migrate.ts",
    "restartPolicyType": "NEVER"
  }
}
