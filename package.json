{
  "name": "create-bnh",
  "bin": {
    "create-bnh": "bin/create.ts"
  },
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "turbo db:generate --filter=@app/migrate",
    "db:migrate": "turbo db:migrate --filter=@app/migrate",
    "test": "turbo test"
  },
  "overrides": {
    "eslint": "^9.39.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.1.7",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
