{
  "name": "create-bnh",
  "bin": {
    "create-bnh": "bin/create.ts"
  },
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "turbo db:generate --filter=@app/migrate",
    "db:migrate": "turbo db:migrate --filter=@app/migrate",
    "test": "turbo test",
    "seed": "bun --env-file=.env scripts/seed.ts"
  },
  "overrides": {
    "eslint": "^9.39.4"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "better-auth": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
