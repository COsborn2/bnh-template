# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/myapp

# better-auth
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# Server
PORT=3001

# App
APP_NAME=MyApp
APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=MyApp <onboarding@resend.dev>

# Cloudflare Turnstile (test keys - always passes)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Google OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# WebSocket server (PORT is set in the WS dev script, not here)
WS_AUTH_URL=http://localhost:3001/api/auth/get-session
WS_AUTHORIZE_URL=http://localhost:3001/api/ws/authorize
WS_EVENTS_URL=http://localhost:3001/api/ws/events
WS_API_SECRET=dev-ws-secret-change-in-production
